{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rechnungs-manager",
  "version": "0.3.6",
  "identifier": "com.leonm.rechnungsmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rechnungs-Manager",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNzNERkEwRTZDNDNFOUEKUldTYVBzVG1vTjl6Z2ZydHVRb2VsalRUZXl1ZmFUM3JsR1dMYzFrZXd2aEpqOXhvY2FOQy83cXEK",
      "endpoints": [
        "https://github.com/Leonlp9/Rechnungen/releases/latest/download/latest.json"
      ]
    }
  }
}
